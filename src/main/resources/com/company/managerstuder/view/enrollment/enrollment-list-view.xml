<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://enrollmentListView.title"
      focusComponent="enrollmentsDataGrid">
    <data>
        <collection id="enrollmentsDc"
                    class="com.company.managerstuder.entity.Enrollment">
            <fetchPlan extends="_base">
                <property name="studers" fetchPlan="_base"/>
                <property name="courses" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="enrollmentsDl" readOnly="true">
                <query>
                    <![CDATA[select e from Enrollment e]]>
                </query>
            </loader>
        </collection>
        <instance id="enrollmentDc"
                  class="com.company.managerstuder.entity.Enrollment">
            <fetchPlan extends="_base">
                <property name="studers" fetchPlan="_base"/>
                <property name="courses" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="enrollmentDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%">
                <genericFilter id="genericFilter"
                               dataLoader="enrollmentsDl">
                    <properties include=".*"/>
                </genericFilter>
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="enrollmentsDataGrid.createAction"/>
                    <button id="editButton" action="enrollmentsDataGrid.editAction"/>
                    <button id="removeButton" action="enrollmentsDataGrid.removeAction"/>
                    <simplePagination id="pagination" dataLoader="enrollmentsDl"/>
                </hbox>
                <dataGrid id="enrollmentsDataGrid"
                          width="100%"
                          minHeight="20em"
                          dataContainer="enrollmentsDc"
                          columnReorderingAllowed="true">
                    <actions>
                        <action id="createAction" type="list_create"/>
                        <action id="editAction" type="list_edit"/>
                        <action id="removeAction" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="point"/>
                        <column property="studers"/>
                        <column property="courses"/>
                    </columns>
                </dataGrid>
                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <formLayout id="form" dataContainer="enrollmentDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <textField id="pointField" property="point"/>
                    <entityPicker id="studersField" property="studers">
                        <actions>
                            <action id="entityLookupAction" type="entity_lookup"/>
                            <action id="entityClearAction" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                    <entityPicker id="coursesField" property="courses">
                        <actions>
                            <action id="entityLookupAction" type="entity_lookup"/>
                            <action id="entityClearAction" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
