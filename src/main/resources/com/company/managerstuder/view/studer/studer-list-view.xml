<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://studerListView.title"
      focusComponent="studersDataGrid">
    <data>
        <collection id="studersDc"
                    class="com.company.managerstuder.entity.Studer">
            <fetchPlan extends="_base">
                <property name="enrollments" fetchPlan="_base"/>
                <property name="age"/>
            </fetchPlan>
            <loader id="studersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Studer e]]>
                </query>
            </loader>
        </collection>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout>
        <genericFilter id="genericFilter"
                       dataLoader="studersDl">
            <properties include=".*"/>
        </genericFilter>
        <hbox id="buttonsPanel" classNames="buttons-panel">
            <button id="createButton" action="studersDataGrid.createAction"/>
            <button id="editButton" action="studersDataGrid.editAction"/>
            <button id="removeButton" action="studersDataGrid.removeAction"/>
            <simplePagination id="pagination" dataLoader="studersDl"/>
        </hbox>
        <dataGrid id="studersDataGrid"
                  width="100%"
                  minHeight="20em"
                  dataContainer="studersDc"
                  columnReorderingAllowed="true">
            <actions>
                <action id="createAction" type="list_create"/>
                <action id="editAction" type="list_edit"/>
                <action id="removeAction" type="list_remove"/>
            </actions>
            <columns resizable="true">
                <column property="code"/>
                <column property="name"/>
                <column property="dob"/>
                <column property="age"/>
                <column property="cccd"/>
                <column property="address"/>
                <column property="numberPhone"/>
            </columns>
        </dataGrid>
        <hbox id="lookupActions" visible="false">
            <button id="selectButton" action="selectAction"/>
            <button id="discardButton" action="discardAction"/>
        </hbox>
    </layout>
</view>
