<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<view xmlns="http://jmix.io/schema/flowui/view"
      xmlns:c="http://jmix.io/schema/flowui/jpql-condition"
      title="msg://teacherListView.title"
      focusComponent="teachersDataGrid">
    <data>
        <collection id="teachersDc"
                    class="com.company.managerstuder.entity.Teacher">
            <fetchPlan extends="_base">
                <property name="schools" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="teachersDl" readOnly="true">
                <query>
                    <![CDATA[select e from Teacher e]]>
                </query>
            </loader>
        </collection>
        <instance id="teacherDc"
                  class="com.company.managerstuder.entity.Teacher">
            <fetchPlan extends="_base">
                <property name="schools" fetchPlan="_base"/>
            </fetchPlan>
            <loader id="teacherDl"/>
        </instance>
    </data>
    <facets>
        <dataLoadCoordinator auto="true"/>
        <urlQueryParameters>
            <genericFilter component="genericFilter"/>
            <pagination component="pagination"/>
        </urlQueryParameters>
    </facets>
    <actions>
        <action id="selectAction" type="lookup_select"/>
        <action id="discardAction" type="lookup_discard"/>
    </actions>
    <layout padding="false">
        <formLayout id="layoutWrapper" classNames="master-detail-layout" height="100%">
            <vbox id="listLayout" height="100%">
                <genericFilter id="genericFilter"
                               dataLoader="teachersDl">
                    <properties include=".*"/>
                </genericFilter>
                <hbox id="buttonsPanel" classNames="buttons-panel">
                    <button id="createButton" action="teachersDataGrid.createAction"/>
                    <button id="editButton" action="teachersDataGrid.editAction"/>
                    <button id="removeButton" action="teachersDataGrid.removeAction"/>
                    <simplePagination id="pagination" dataLoader="teachersDl"/>
                </hbox>
                <dataGrid id="teachersDataGrid"
                          width="100%"
                          minHeight="20em"
                          dataContainer="teachersDc"
                          columnReorderingAllowed="true">
                    <actions>
                        <action id="createAction" type="list_create"/>
                        <action id="editAction" type="list_edit"/>
                        <action id="removeAction" type="list_remove"/>
                    </actions>
                    <columns resizable="true">
                        <column property="name"/>
                        <column property="dob"/>
                        <column property="address"/>
                        <column property="numberPhone"/>
                        <column property="schools"/>
                    </columns>
                </dataGrid>
                <hbox id="lookupActions" visible="false">
                    <button id="selectButton" action="selectAction"/>
                    <button id="discardButton" action="discardAction"/>
                </hbox>
            </vbox>
            <vbox id="detailsLayout" height="100%">
                <formLayout id="form" dataContainer="teacherDc">
                    <responsiveSteps>
                        <responsiveStep minWidth="0" columns="1"/>
                        <responsiveStep minWidth="40em" columns="2"/>
                    </responsiveSteps>
                    <textField id="nameField" property="name"/>
                    <datePicker id="dobField" property="dob"/>
                    <textField id="addressField" property="address"/>
                    <textField id="numberPhoneField" property="numberPhone"/>
                    <entityPicker id="schoolsField" property="schools">
                        <actions>
                            <action id="entityLookupAction" type="entity_lookup"/>
                            <action id="entityClearAction" type="entity_clear"/>
                        </actions>
                    </entityPicker>
                </formLayout>
                <hbox id="detailActions">
                    <button id="saveButton" text="msg:///actions.Save" icon="CHECK" themeNames="primary"/>
                    <button id="cancelButton" text="msg:///actions.Cancel" icon="BAN"/>
                </hbox>
            </vbox>
        </formLayout>
    </layout>
</view>
